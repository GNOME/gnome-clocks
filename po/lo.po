msgid "Clocks"
msgstr "ໂມງ"

#: data/org.gnome.clocks.desktop.in.in:4
msgid "Clocks for world times, plus alarms, stopwatch and a timer"
msgstr "ໂມງສຳລັບເວລາໂລກ, ພ້ອມໂມງປຸກ, ໂມງຈັບເວລາ ແລະ ໂມງນັບຖອຍຫຼັງ"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.clocks.desktop.in.in:6
msgid "time;timer;alarm;world clock;stopwatch;time zone;"
msgstr "ເວລາ;ໂມງນັບຖອຍຫຼັງ;ໂມງປຸກ;ໂມງໂລກ;ໂມງຈັບເວລາ;ເຂດເວລາ;"

#: data/org.gnome.clocks.desktop.in.in:16
msgid "Allows world clocks to be displayed for your time zone."
msgstr "ອະນຸຍາດໃຫ້ສະແດງໂມງໂລກສຳລັບເຂດເວລາຂອງທ່ານ."

#: data/org.gnome.clocks.gschema.xml.in:5
msgid "Configured world clocks"
msgstr "ໂມງໂລກທີ່ກຳນົດຄ່າໄວ້"

#: data/org.gnome.clocks.gschema.xml.in:6
msgid "List of world clocks to show."
msgstr "ລາຍການໂມງໂລກທີ່ຈະສະແດງ."

#: data/org.gnome.clocks.gschema.xml.in:12
msgid "Configured alarms"
msgstr "ໂມງປຸກທີ່ກຳນົດຄ່າໄວ້"

#: data/org.gnome.clocks.gschema.xml.in:13
msgid "List of alarms set."
msgstr "ລາຍການໂມງປຸກທີ່ຕັ້ງໄວ້."

#: data/org.gnome.clocks.gschema.xml.in:19
msgid "Configured Timers"
msgstr "ໂມງນັບຖອຍຫຼັງທີ່ກຳນົດຄ່າໄວ້"

#: data/org.gnome.clocks.gschema.xml.in:20
msgid "List of timers set."
msgstr "ລາຍການໂມງນັບຖອຍຫຼັງທີ່ຕັ້ງໄວ້."

#: data/org.gnome.clocks.gschema.xml.in:26
msgid "Geolocation support"
msgstr "ຮອງຮັບການລະບຸຕຳແໜ່ງ"

#: data/org.gnome.clocks.gschema.xml.in:27
msgid "Turn geolocation support on and off."
msgstr "ເປີດ ແລະ ປິດການຮອງຮັບການລະບຸຕຳແໜ່ງ."

#: data/org.gnome.clocks.gschema.xml.in:44
msgid "Window maximized"
msgstr "ຂະຫຍາຍໜ້າຕ່າງ"

#: data/org.gnome.clocks.gschema.xml.in:45
msgid "Whether the window is maximized."
msgstr "ສະຖານະວ່າໜ້າຕ່າງຖືກຂະຫຍາຍຫຼືບໍ່."

#: data/org.gnome.clocks.gschema.xml.in:51
msgid "Window width and height"
msgstr "ຄວາມກວ້າງ ແລະ ຄວາມສູງຂອງໜ້າຕ່າງ"

#: data/org.gnome.clocks.gschema.xml.in:52
msgid "Width and height of the window."
msgstr "ຄວາມກວ້າງ ແລະ ຄວາມສູງຂອງໜ້າຕ່າງ."

#: data/org.gnome.clocks.gschema.xml.in:58
msgid "Panel state"
msgstr "ສະຖານະແຖບ"

#: data/org.gnome.clocks.gschema.xml.in:59
msgid "Current clock panel."
msgstr "ແຖບໂມງປັດຈຸບັນ."

#: data/org.gnome.clocks.metainfo.xml.in.in:7
msgid "Keep track of time"
msgstr "ຕິດຕາມເວລາ"

#: data/org.gnome.clocks.metainfo.xml.in.in:9
msgid ""
"A simple and elegant clock application. It includes world clocks, alarms, a "
"stopwatch, and timers."
msgstr "ແອັບໂມງທີ່ລຽບງ່າຍ ແລະ ສວຍງາມ. ເຊິ່ງລວມມີໂມງໂລກ, ໂມງປຸກ, ໂມງຈັບເວລາ ແລະ ໂມງນັບຖອຍຫຼັງ."

#: data/org.gnome.clocks.metainfo.xml.in.in:14
msgid "Show the time in different cities around the world"
msgstr "ສະແດງເວລາໃນເມືອງຕ່າງໆທົ່ວໂລກ"

#: data/org.gnome.clocks.metainfo.xml.in.in:15
msgid "Set alarms to wake you up"
msgstr "ຕັ້ງໂມງປຸກເພື່ອປຸກທ່ານ"

#: data/org.gnome.clocks.metainfo.xml.in.in:16
msgid "Measure elapsed time with an accurate stopwatch"
msgstr "ວັດແທກເວລາທີ່ຜ່ານໄປດ້ວຍໂມງຈັບເວລາທີ່ຊັດເຈນ"

#: data/org.gnome.clocks.metainfo.xml.in.in:17
msgid "Set timers to properly cook your food"
msgstr "ຕັ້ງໂມງນັບຖອຍຫຼັງເພື່ອປຸງແຕ່ງອາຫານຂອງທ່ານໃຫ້ພໍດີ"

#: data/org.gnome.clocks.metainfo.xml.in.in:34
msgid "Initial screen"
msgstr "ໜ້າຈໍເລີ່ມຕົ້ນ"

#: data/org.gnome.clocks.metainfo.xml.in.in:38
msgid "Alarms screen"
msgstr "ໜ້າຈໍໂມງປຸກ"

#: data/org.gnome.clocks.metainfo.xml.in.in:42
msgid "Stopwatch screen"
msgstr "ໜ້າຈໍໂມງຈັບເວລາ"

#: data/org.gnome.clocks.metainfo.xml.in.in:46
msgid "Timer screen"
msgstr "ໜ້າຈໍໂມງນັບຖອຍຫຼັງ"

